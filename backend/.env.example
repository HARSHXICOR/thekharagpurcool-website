# Application Configuration
PORT=3001
APP_ENV=development

# Database (PostgreSQL 16 matching docker-compose)
DATABASE_URL="postgresql://tgw_user:tgw_password@localhost:5432/tgw_db?schema=public"

# Cache & Queues (Redis matching docker-compose)
REDIS_URL="redis://localhost:6379"

# Security and JWT Toggles
JWT_SECRET="tgw-super-secret-access-token-key-2026-very-secure"
JWT_REFRESH_SECRET="tgw-super-secret-refresh-token-key-2026-very-secure"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# Meta Graph API Integration Credentials (Placeholder/Mocks)
META_APP_ID="mock-meta-app-id"
META_APP_SECRET="mock-meta-app-secret"
META_REDIRECT_URI="http://localhost:3001/api/v1/meta/callback"

# Token Envelope Encryption Key (Must be exactly 32 characters for AES-256)
TOKEN_ENCRYPTION_KEY="tgw_secure_master_key_for_meta"

# Third Party Services
EMAIL_PROVIDER_API_KEY="mock-resend-key"
FRONTEND_ORIGIN="http://localhost:3000"
