datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. Users, Organizations & Sessions
// ==========================================

model User {
  id               String       @id @default(uuid()) @db.Uuid
  email            String       @unique
  passwordHash     String?      @map("password_hash")
  fullName         String       @map("full_name") @db.VarChar(120)
  phone            String?      @db.VarChar(20)
  avatarUrl        String?      @map("avatar_url")
  defaultRole      String       @map("default_role") @db.VarChar(30) // e.g. visitor, subscriber, client_user, account_manager, content_manager, analyst, admin, super_admin
  status           String       @default("active") @db.VarChar(20)   // e.g. active, suspended, pending
  emailVerifiedAt  DateTime?    @map("email_verified_at") @db.Timestamptz
  lastLoginAt      DateTime?    @map("last_login_at") @db.Timestamptz
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz

  memberships       OrganizationMembership[]
  inquiriesAssigned Inquiry[]                @relation("AssignedInquiries")
  campaignsOwned    Campaign[]               @relation("OwnedCampaigns")
  reportsGenerated  Report[]                 @relation("GeneratedReports")
  blogPosts         BlogPost[]               @relation("AuthoredBlogs")
  mediaUploaded     MediaAsset[]             @relation("UploadedMedia")
  notifications     Notification[]
  sessions          Session[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  emailVerifications EmailVerification[]
  auditLogs         AuditLog[]               @relation("ActorAuditLogs")

  @@index([status, createdAt(sort: Desc)])
  @@map("users")
}

model Organization {
  id              String       @id @default(uuid()) @db.Uuid
  name            String       @db.VarChar(160)
  slug            String       @unique @db.VarChar(120)
  industry        String?      @db.VarChar(80)
  websiteUrl      String?      @map("website_url")
  instagramHandle String?      @map("instagram_handle") @db.VarChar(80)
  billingEmail    String?      @map("billing_email")
  timezone        String       @default("Asia/Kolkata") @db.VarChar(64)
  status          String       @default("active") @db.VarChar(20)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz

  memberships       OrganizationMembership[]
  inquiriesQualified Inquiry[]
  campaigns         Campaign[]
  reports           Report[]
  mediaAssets       MediaAsset[]
  instagramAccounts InstagramAccount[]

  @@index([industry, status])
  @@map("organizations")
}

model OrganizationMembership {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           String       @db.VarChar(30) // e.g. org_owner, org_admin, org_member
  status         String       @default("active") @db.VarChar(20)
  invitedById    String?      @map("invited_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_memberships")
}

// ==========================================
// 2. CMS Core Tables
// ==========================================

model Service {
  id               String       @id @default(uuid()) @db.Uuid
  slug             String       @unique @db.VarChar(100)
  name             String       @db.VarChar(120)
  shortDescription String?      @map("short_description")
  description      String?
  category         String?      @db.VarChar(60)
  displayOrder     Int          @default(0) @map("display_order")
  isActive         Boolean      @default(true) @map("is_active")
  metadata         Json?
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz

  inquiries        Inquiry[]

  @@map("services")
}

model PricingPlan {
  id           String       @id @default(uuid()) @db.Uuid
  slug         String       @unique @db.VarChar(100)
  name         String       @db.VarChar(120)
  tagline      String?
  billingModel String       @map("billing_model") @db.VarChar(30) // campaign, monthly, custom
  monthlyPrice Decimal?     @map("monthly_price") @db.Decimal(12, 2)
  annualPrice  Decimal?     @map("annual_price") @db.Decimal(12, 2)
  currency     String       @default("INR") @db.Char(3)
  isFeatured   Boolean      @default(false) @map("is_featured")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz

  features     PlanFeature[]

  @@map("pricing_plans")
}

model PlanFeature {
  id           String      @id @default(uuid()) @db.Uuid
  planId       String      @map("plan_id") @db.Uuid
  featureText  String      @map("feature_text")
  featureType  String      @map("feature_type") @db.VarChar(20) // included, excluded
  displayOrder Int         @default(0) @map("display_order")

  plan         PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_features")
}

model BlogPost {
  id                String       @id @default(uuid()) @db.Uuid
  slug              String       @unique @db.VarChar(160)
  title             String       @db.VarChar(220)
  excerpt           String?
  content           Json
  featuredImageUrl  String?      @map("featured_image_url")
  category          String?      @db.VarChar(60)
  tags              String[]     @default([])
  authorId          String       @map("author_id") @db.Uuid
  status            String       @db.VarChar(20) // draft, scheduled, published, archived
  publishedAt       DateTime?    @map("published_at") @db.Timestamptz
  seoTitle          String?      @map("seo_title") @db.VarChar(220)
  seoDescription    String?      @map("seo_description") @db.VarChar(320)
  readTimeMinutes   Int          @default(0) @map("read_time_minutes")
  viewCount         BigInt       @default(0) @map("view_count")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz

  author            User         @relation("AuthoredBlogs", fields: [authorId], references: [id])

  @@index([status, publishedAt(sort: Desc)])
  @@map("blog_posts")
}

model CaseStudy {
  id                String       @id @default(uuid()) @db.Uuid
  slug              String       @unique @db.VarChar(160)
  title             String       @db.VarChar(220)
  clientDisplayName String       @map("client_display_name") @db.VarChar(180)
  industry          String?      @db.VarChar(80)
  challenge         String?
  solution          String?
  results           Json?
  durationLabel     String?      @map("duration_label") @db.VarChar(60)
  featuredImageUrl  String?      @map("featured_image_url")
  status            String       @db.VarChar(20) // draft, published, archived
  publishedAt       DateTime?    @map("published_at") @db.Timestamptz
  sortOrder         Int          @default(0) @map("sort_order")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz

  @@map("case_studies")
}

model Testimonial {
  id               String       @id @default(uuid()) @db.Uuid
  clientName       String       @map("client_name") @db.VarChar(120)
  clientRole       String       @map("client_role") @db.VarChar(160)
  organizationName String?      @map("organization_name") @db.VarChar(160)
  avatarUrl        String?      @map("avatar_url")
  rating           Int          @db.SmallInt
  quote            String
  hasVideo         Boolean      @default(false) @map("has_video")
  videoUrl         String?      @map("video_url")
  status           String       @db.VarChar(20) // draft, published, archived
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz

  @@map("testimonials")
}

model NewsletterSubscriber {
  id             String       @id @default(uuid()) @db.Uuid
  email          String       @unique
  status         String       @db.VarChar(20) // pending, subscribed, unsubscribed, bounced
  source         String?      @db.VarChar(50)
  confirmedAt    DateTime?    @map("confirmed_at") @db.Timestamptz
  unsubscribedAt DateTime?    @map("unsubscribed_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  @@map("newsletter_subscribers")
}

// ==========================================
// 3. Lead-Capture & Sales
// ==========================================

model Inquiry {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(120)
  email          String
  phone          String       @db.VarChar(20)
  companyName    String?      @map("company_name") @db.VarChar(160)
  instagramHandle String?      @map("instagram_handle") @db.VarChar(120)
  serviceId      String?      @map("service_id") @db.Uuid
  budgetBand     String       @map("budget_band") @db.VarChar(30) // e.g. scale, growth, standard
  message        String?
  source         String       @db.VarChar(50) // contact_form, cta, pricing, whatsapp, manual
  status         String       @default("new") @db.VarChar(30) // new, qualified, lost, in_progress
  assignedToId   String?      @map("assigned_to") @db.Uuid
  organizationId String?      @map("organization_id") @db.Uuid
  utm            Json?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz

  service        Service?     @relation(fields: [serviceId], references: [id])
  assignedTo     User?        @relation("AssignedInquiries", fields: [assignedToId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  campaigns      Campaign[]

  @@index([status, createdAt(sort: Desc)])
  @@index([assignedToId, status])
  @@map("inquiries")
}

// ==========================================
// 4. Operations & Tracking
// ==========================================

model Campaign {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  inquiryId      String?      @map("inquiry_id") @db.Uuid
  name           String       @db.VarChar(180)
  slug           String?      @unique @db.VarChar(160)
  campaignType   String       @map("campaign_type") @db.VarChar(60)
  status         String       @db.VarChar(30) // draft, proposed, active, completed, cancelled
  objective      String?      @db.VarChar(60) // reach, footfall, leads, awareness, sales, event_attendance
  budget         Decimal      @db.Decimal(12, 2)
  currency       String       @default("INR") @db.Char(3)
  startDate      DateTime?    @map("start_date") @db.Date
  endDate        DateTime?    @map("end_date") @db.Date
  brief          String?
  internalNotes  String?      @map("internal_notes")
  ownerId        String?      @map("owner_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inquiry        Inquiry?     @relation(fields: [inquiryId], references: [id])
  owner          User?        @relation("OwnedCampaigns", fields: [ownerId], references: [id])
  deliverables   CampaignDeliverable[]
  metrics        CampaignMetric[]
  reports        Report[]
  mediaAssets    MediaAsset[]

  @@index([organizationId, status, startDate(sort: Desc)])
  @@index([ownerId, status])
  @@map("campaigns")
}

model CampaignDeliverable {
  id              String       @id @default(uuid()) @db.Uuid
  campaignId      String       @map("campaign_id") @db.Uuid
  deliverableType String       @map("deliverable_type") @db.VarChar(50) // reel, story, carousel, event_coverage, review, giveaway, report
  title           String       @db.VarChar(180)
  status          String       @db.VarChar(30) // planned, in_progress, review, published, archived
  scheduledAt     DateTime?    @map("scheduled_at") @db.Timestamptz
  publishedAt     DateTime?    @map("published_at") @db.Timestamptz
  platform        String       @db.VarChar(30) // instagram, youtube, website, offline
  linkUrl         String?      @map("link_url")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz

  campaign        Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_deliverables")
}

model CampaignMetric {
  id               String       @id @default(uuid()) @db.Uuid
  campaignId       String       @map("campaign_id") @db.Uuid
  metricDate       DateTime     @map("metric_date") @db.Date
  reach            Int          @default(0)
  impressions      Int          @default(0)
  likes            Int          @default(0)
  comments         Int          @default(0)
  shares           Int          @default(0)
  saves            Int          @default(0)
  profileVisits    Int          @default(0) @map("profile_visits")
  linkClicks       Int          @default(0) @map("link_clicks")
  followerGrowth   Int          @default(0) @map("follower_growth")
  footfallEstimate Int?         @map("footfall_estimate")
  revenueEstimate  Decimal?     @map("revenue_estimate") @db.Decimal(12, 2)
  source           String       @db.VarChar(30) // manual, import, api

  campaign         Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, metricDate, source])
  @@index([campaignId, metricDate(sort: Desc)])
  @@map("campaign_metrics")
}

model Report {
  id             String       @id @default(uuid()) @db.Uuid
  campaignId     String?      @map("campaign_id") @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  reportType     String       @map("report_type") @db.VarChar(40) // campaign_summary, monthly, custom_range
  status         String       @db.VarChar(20) // queued, ready, failed, expired
  storageKey     String?      @map("storage_key")
  format         String       @db.VarChar(10) // pdf, csv, xlsx, json
  dateFrom       DateTime     @map("date_from") @db.Date
  dateTo         DateTime     @map("date_to") @db.Date
  generatedById  String?      @map("generated_by") @db.Uuid
  expiresAt      DateTime?    @map("expires_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  campaign       Campaign?    @relation(fields: [campaignId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedBy    User?        @relation("GeneratedReports", fields: [generatedById], references: [id])

  @@map("reports")
}

// ==========================================
// 5. Media & Notifications
// ==========================================

model MediaAsset {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String?      @map("organization_id") @db.Uuid
  campaignId       String?      @map("campaign_id") @db.Uuid
  uploadedById     String?      @map("uploaded_by") @db.Uuid
  storageKey       String       @map("storage_key")
  publicUrl        String?      @map("public_url")
  mimeType         String       @map("mime_type") @db.VarChar(100)
  sizeBytes        BigInt       @map("size_bytes")
  width            Int?
  height           Int?
  durationSeconds  Int?         @map("duration_seconds")
  checksumSha256   String       @map("checksum_sha256") @db.Char(64)
  processingStatus String       @map("processing_status") @db.VarChar(20) // uploaded, processing, ready, failed
  kind             String       @db.VarChar(20) // image, video, document
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz

  organization     Organization? @relation(fields: [organizationId], references: [id])
  campaign         Campaign?    @relation(fields: [campaignId], references: [id])
  uploadedBy       User?        @relation("UploadedMedia", fields: [uploadedById], references: [id])

  @@index([campaignId, createdAt(sort: Desc)])
  @@map("media_assets")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    @db.VarChar(50)
  title     String    @db.VarChar(180)
  body      String
  data      Json?
  channel   String    @db.VarChar(20) // in_app, email, push, sms
  readAt    DateTime? @map("read_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@map("notifications")
}

// ==========================================
// 6. Authentication Entities
// ==========================================

model Session {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  deviceName        String?      @map("device_name") @db.VarChar(120)
  deviceFingerprint String?      @map("device_fingerprint") @db.VarChar(255)
  ip                String?      @db.VarChar(45)
  userAgent         String?      @map("user_agent")
  lastSeenAt        DateTime     @map("last_seen_at") @db.Timestamptz
  revokedAt         DateTime?    @map("revoked_at") @db.Timestamptz
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens     RefreshToken[]

  @@map("sessions")
}

model RefreshToken {
  id            String    @id @default(uuid()) @db.Uuid
  sessionId     String    @map("session_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tokenHash     String    @map("token_hash") @db.Char(64)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz
  rotatedFromId String?   @map("rotated_from") @db.Uuid
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  session       Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.Char(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model EmailVerification {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") @db.Char(64)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model AuditLog {
  id           String    @id @default(uuid()) @db.Uuid
  actorUserId  String?   @map("actor_user_id") @db.Uuid
  entityType   String    @map("entity_type") @db.VarChar(60)
  entityId     String    @map("entity_id") @db.Uuid
  action       String    @map("action") @db.VarChar(40)
  before       Json?
  after        Json?
  ip           String?   @db.VarChar(45)
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  actor        User?     @relation("ActorAuditLogs", fields: [actorUserId], references: [id])

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ==========================================
// 7. Meta / Instagram Graph API Models
// ==========================================

model InstagramAccount {
  id                  String       @id @default(uuid()) @db.Uuid
  organizationId      String       @map("organization_id") @db.Uuid
  authorizedByUserId  String       @map("authorized_by_user_id") @db.Uuid
  instagramUserId     String       @map("instagram_user_id") @db.VarChar(64)
  pageId              String       @map("page_id") @db.VarChar(64)
  pageName            String?      @map("page_name") @db.VarChar(160)
  username            String       @db.VarChar(120)
  displayName         String?      @map("display_name") @db.VarChar(160)
  accountType         String       @map("account_type") @db.VarChar(20) // e.g. BUSINESS, CREATOR
  biography           String?
  website             String?
  profilePictureUrl   String?      @map("profile_picture_url")
  followersCount      Int?         @map("followers_count")
  followsCount        Int?         @map("follows_count")
  mediaCount          Int?         @map("media_count")
  metaAppId           String       @map("meta_app_id") @db.VarChar(40)
  status              String       @default("active") @db.VarChar(30)
  connectionStatus    String       @default("connected") @map("connection_status") @db.VarChar(30) // connected, reauth_required, disconnected
  lastProfileSyncAt   DateTime?    @map("last_profile_sync_at") @db.Timestamptz
  lastMediaSyncAt     DateTime?    @map("last_media_sync_at") @db.Timestamptz
  lastInsightsSyncAt  DateTime?    @map("last_insights_sync_at") @db.Timestamptz
  reauthRequiredAt    DateTime?    @map("reauth_required_at") @db.Timestamptz
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?    @map("deleted_at") @db.Timestamptz

  // Capability Probing columns
  supportsDemographics                Boolean            @default(false) @map("supports_demographics")
  supportsCountryBreakdown            Boolean            @default(false) @map("supports_country_breakdown")
  supportsCityBreakdown               Boolean            @default(false) @map("supports_city_breakdown")
  supportsHistoricalFollowerInsights  Boolean            @default(false) @map("supports_historical_follower_insights")
  videoMetricType                     VideoMetricType?   @map("video_metric_type")
  syncStatus                          SyncStatus         @default(DEMO) @map("sync_status")

  // Sync Observability metrics
  lastSuccessfulSyncAt                DateTime?          @map("last_successful_sync_at") @db.Timestamptz
  lastSyncAttemptAt                   DateTime?          @map("last_sync_attempt_at") @db.Timestamptz
  lastSyncError                       String?            @map("last_sync_error")

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tokens              InstagramToken[]
  media               InstagramMedia[]
  
  // Snapshots & Rollups Relations
  followerSnapshots         InstagramFollowerSnapshot[]
  audienceSnapshots         InstagramAudienceSnapshot[]
  followerMonthlySnapshots  InstagramFollowerMonthlySnapshot[]
  audienceMonthlySnapshots  InstagramAudienceMonthlySnapshot[]

  @@unique([organizationId, instagramUserId])
  @@index([organizationId, status])
  @@index([connectionStatus, updatedAt(sort: Desc)])
  @@map("instagram_accounts")
}

model InstagramToken {
  id                     String    @id @default(uuid()) @db.Uuid
  instagramAccountId     String    @map("instagram_account_id") @db.Uuid
  tokenType              String    @map("token_type") @db.VarChar(30) // user_long_lived, page, system_user
  accessTokenCiphertext  String    @map("access_token_ciphertext")
  accessTokenIv          String    @map("access_token_iv")
  accessTokenAuthTag     String    @map("access_token_auth_tag")
  refreshTokenCiphertext String?   @map("refresh_token_ciphertext")
  scopes                 String[]  @default([])
  grantedScopes          String[]  @default([]) @map("granted_scopes")
  expiresAt              DateTime? @map("expires_at") @db.Timestamptz
  issuedAt               DateTime  @map("issued_at") @db.Timestamptz
  lastRefreshedAt        DateTime? @map("last_refreshed_at") @db.Timestamptz
  refreshStatus          String    @default("valid") @map("refresh_status") @db.VarChar(20) // valid, expired, failed
  lastErrorCode          String?   @map("last_error_code") @db.VarChar(60)
  lastErrorMessage       String?   @map("last_error_message")
  keyVersion             String    @map("key_version") @db.VarChar(30)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  revokedAt              DateTime? @map("revoked_at") @db.Timestamptz

  instagramAccount       InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@index([instagramAccountId, tokenType, revokedAt])
  @@index([expiresAt, refreshStatus])
  @@map("instagram_tokens")
}

model InstagramMedia {
  id                   String       @id @default(uuid()) @db.Uuid
  instagramAccountId   String       @map("instagram_account_id") @db.Uuid
  igMediaId            String       @map("ig_media_id") @db.VarChar(64)
  parentIgMediaId      String?      @map("parent_ig_media_id") @db.VarChar(64)
  mediaType            String       @map("media_type") @db.VarChar(30) // IMAGE, VIDEO, CAROUSEL_ALBUM, STORY, REEL
  mediaProductType     String?      @map("media_product_type") @db.VarChar(30)
  caption              String?
  permalink            String?
  thumbnailUrl         String?      @map("thumbnail_url")
  mediaUrl             String?      @map("media_url")
  shortcode            String?      @db.VarChar(50)
  likeCount            Int?         @map("like_count")
  commentsCount        Int?         @map("comments_count")
  isCommentEnabled     Boolean?     @map("is_comment_enabled")
  hasChildren          Boolean      @default(false) @map("has_children")
  publishedAt          DateTime     @map("published_at") @db.Timestamptz
  fetchedAt            DateTime     @map("fetched_at") @db.Timestamptz
  deletedOnInstagramAt DateTime?    @map("deleted_on_instagram_at") @db.Timestamptz
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  instagramAccount     InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  mediaMetrics         InstagramMediaMetric[]

  @@unique([instagramAccountId, igMediaId])
  @@index([instagramAccountId, publishedAt(sort: Desc)])
  @@index([mediaType, publishedAt(sort: Desc)])
  @@map("instagram_media")
}

model InstagramMediaMetric {
  id                 String         @id @default(uuid()) @db.Uuid
  instagramMediaId   String         @map("instagram_media_id") @db.Uuid
  instagramAccountId String         @map("instagram_account_id") @db.Uuid
  metricDate         DateTime       @map("metric_date") @db.Date
  snapshotAt         DateTime       @map("snapshot_at") @db.Timestamptz
  plays              Int?
  views              Int?           @map("video_views") // generic view/plays count
  reach              Int            @default(0)
  impressions        Int            @default(0)
  likes              Int            @default(0)
  comments           Int            @default(0)
  shares             Int            @default(0)
  saves              Int            @default(0)
  engagement         Float          @default(0)
  savedCount         Int            @default(0) @map("saved_count")

  instagramMedia     InstagramMedia @relation(fields: [instagramMediaId], references: [id], onDelete: Cascade)

  @@unique([instagramMediaId, metricDate])
  @@index([instagramMediaId, metricDate(sort: Desc)])
  @@map("instagram_media_metrics")
}

// ==========================================
// 8. Meta / Instagram Snapshots, Rollups & Enums
// ==========================================

enum AudienceBreakdownType {
  AGE_GENDER
  COUNTRY
  CITY
}

enum VideoMetricType {
  VIEWS
  PLAYS
  VIDEO_VIEWS
}

enum SyncStatus {
  LIVE
  SYNCING
  PARTIAL
  ERROR
  DEMO
}

model InstagramFollowerSnapshot {
  id                 String           @id @default(uuid()) @db.Uuid
  instagramAccountId String           @map("instagram_account_id") @db.Uuid
  followersCount     Int              @map("followers_count")
  followsCount       Int              @map("follows_count")
  mediaCount         Int              @map("media_count")
  snapshotDate       DateTime         @map("snapshot_date") @db.Date
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz

  instagramAccount   InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@unique([instagramAccountId, snapshotDate])
  @@map("instagram_follower_snapshots")
}

model InstagramAudienceSnapshot {
  id                 String                @id @default(uuid()) @db.Uuid
  instagramAccountId String                @map("instagram_account_id") @db.Uuid
  breakdownType      AudienceBreakdownType @map("breakdown_type")
  key                String                @db.VarChar(120) // e.g. "18-24", "IN", "Kolkata"
  value              Int
  snapshotDate       DateTime              @map("snapshot_date") @db.Date
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz

  instagramAccount   InstagramAccount      @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@unique([instagramAccountId, breakdownType, key, snapshotDate])
  @@map("instagram_audience_snapshots")
}

model InstagramFollowerMonthlySnapshot {
  id                 String           @id @default(uuid()) @db.Uuid
  instagramAccountId String           @map("instagram_account_id") @db.Uuid
  followersCount     Int              @map("followers_count")
  followsCount       Int              @map("follows_count")
  mediaCount         Int              @map("media_count")
  year               Int
  month              Int
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz

  instagramAccount   InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@unique([instagramAccountId, year, month])
  @@map("instagram_follower_monthly_snapshots")
}

model InstagramAudienceMonthlySnapshot {
  id                 String                @id @default(uuid()) @db.Uuid
  instagramAccountId String                @map("instagram_account_id") @db.Uuid
  breakdownType      AudienceBreakdownType @map("breakdown_type")
  key                String                @db.VarChar(120)
  value              Int
  year               Int
  month              Int
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz

  instagramAccount   InstagramAccount      @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@unique([instagramAccountId, breakdownType, key, year, month])
  @@map("instagram_audience_monthly_snapshots")
}
